# Web UI
WEB_PORT=3000
WEB_HOST=127.0.0.1
ADMIN_PASSWORD=

# SMTP Server
SMTP_PORT=2525
SMTP_HOST=0.0.0.0
SMTP_SECURE=false
SMTP_TLS_CERT=
SMTP_TLS_KEY=

# SMTP Authentication (leave empty for no auth)
# Format: user1:pass1,user2:pass2
SMTP_AUTH_USERS=

# Max email size in bytes (default 10MB)
SMTP_MAX_SIZE=10485760

# Default wildcard route: forward all unmatched emails here
# Leave empty to only forward via explicit rules
DEFAULT_BOT_ID=
DEFAULT_CHAT_ID=

# Severity keywords (comma-separated, case-insensitive)
# Format: CRITICAL:keyword1,keyword2;HIGH:keyword1,keyword2;...
SEVERITY_KEYWORDS=CRITICAL:breach,compromised,exploit,ransomware;HIGH:urgent,critical,alert,asap,immediate,incident;MEDIUM:warning,attention,notice;LOW:info,fyi,newsletter
