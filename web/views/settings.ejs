<div class="page">
  <div class="page-header">
    <h1>Settings</h1>
    <button class="btn btn-primary" onclick="saveSettings()">Save &amp; Apply</button>
  </div>

  <div id="settings-saved" class="toast" style="display:none">Settings saved. SMTP server restarted with new config.</div>
  <div id="settings-error" class="toast toast-error" style="display:none"></div>

  <form id="settings-form" onsubmit="return false">
    <div class="settings-card">
      <h2>SMTP Server</h2>
      <div class="form-group">
        <label for="SMTP_PORT">Port</label>
        <input type="number" id="SMTP_PORT" value="<%= smtpPort %>" min="1" max="65535">
        <small>Requires restart. Ports below 1024 need CAP_NET_BIND_SERVICE (enabled in systemd).</small>
      </div>
      <div class="form-group">
        <label for="SMTP_SECURE">TLS Mode</label>
        <select id="SMTP_SECURE">
          <option value="false" <%= smtpSecure === 'true' ? '' : 'selected' %>>Plain / STARTTLS</option>
          <option value="true" <%= smtpSecure === 'true' ? 'selected' : '' %>>SMTPS (TLS on connect)</option>
        </select>
        <small>Requires restart. For STARTTLS, also set TLS cert/key in .env.</small>
      </div>
      <div class="form-group">
        <label for="SMTP_AUTH_USERS">Auth Users</label>
        <input type="text" id="SMTP_AUTH_USERS" value="<%= smtpAuth %>" placeholder="Leave empty for no auth">
        <small>Format: user1:pass1,user2:pass2. Requires restart.</small>
      </div>
      <div class="form-group">
        <label for="SMTP_MAX_SIZE">Max Message Size (bytes)</label>
        <input type="number" id="SMTP_MAX_SIZE" value="<%= smtpMaxSize %>" min="1">
        <small>Default 10485760 (10 MB). Requires restart.</small>
      </div>
    </div>

    <div class="settings-card">
      <h2>Wildcard Default Route</h2>
      <p class="hint">When both are set, unmatched emails forward here without any rules.</p>
      <div class="form-group">
        <label for="DEFAULT_BOT_ID">Default Bot ID</label>
        <input type="text" id="DEFAULT_BOT_ID" value="<%= defaultBotId %>" placeholder="Bot UUID from Bots tab">
      </div>
      <div class="form-group">
        <label for="DEFAULT_CHAT_ID">Default Chat ID</label>
        <input type="text" id="DEFAULT_CHAT_ID" value="<%= defaultChatId %>" placeholder="e.g., 123456789 or @username">
      </div>
    </div>

    <div class="settings-card">
      <h2>Severity Keywords</h2>
      <p class="hint">Format: LEVEL:word1,word2;LEVEL:word1,word2</p>
      <div class="form-group">
        <label for="SEVERITY_KEYWORDS">Keywords</label>
        <textarea id="SEVERITY_KEYWORDS" rows="3" style="width:100%;background:var(--bg);border:1px solid var(--border);border-radius:6px;color:var(--text);padding:0.5rem;font-size:0.85rem;font-family:monospace;resize:vertical;"><%= severityKeywords %></textarea>
      </div>
    </div>
  </form>

  <div class="settings-card">
    <h2>Configuration Guide</h2>

    <h3>Getting a Telegram Bot Token</h3>
    <ol>
      <li>Open Telegram and chat with <a href="https://t.me/BotFather" target="_blank">@BotFather</a></li>
      <li>Send <code>/newbot</code> and follow the prompts</li>
      <li>Copy the token and add it in the Bots tab</li>
    </ol>

    <h3>Finding Your Chat ID</h3>
    <ol>
      <li>Send a message to your bot on Telegram</li>
      <li>Visit <code>https://api.telegram.org/bot&lt;YOUR_TOKEN&gt;/getUpdates</code></li>
      <li>Look for <code>"chat":{"id":123456789}</code> in the response</li>
      <li>Group chats use a negative number like <code>-1001234567890</code></li>
    </ol>

    <h3>Rule Patterns</h3>
    <ul>
      <li><code>*@domain.com</code> - Match all senders from a domain</li>
      <li><code>user@domain.com</code> - Match exact email</li>
      <li><code>*</code> - Match all senders (catch-all)</li>
      <li><code>noreply@*</code> - Match any noreply address</li>
    </ul>

    <h3>TLS Certificates</h3>
    <p class="hint">TLS cert/key paths are set in <code>.env</code> (<code>SMTP_TLS_CERT</code>, <code>SMTP_TLS_KEY</code>) and require a service restart.</p>
  </div>
</div>

<script>
async function saveSettings() {
  const payload = {
    SMTP_PORT: document.getElementById('SMTP_PORT').value,
    SMTP_SECURE: document.getElementById('SMTP_SECURE').value,
    SMTP_AUTH_USERS: document.getElementById('SMTP_AUTH_USERS').value,
    SMTP_MAX_SIZE: document.getElementById('SMTP_MAX_SIZE').value,
    DEFAULT_BOT_ID: document.getElementById('DEFAULT_BOT_ID').value,
    DEFAULT_CHAT_ID: document.getElementById('DEFAULT_CHAT_ID').value,
    SEVERITY_KEYWORDS: document.getElementById('SEVERITY_KEYWORDS').value,
  };
  try {
    const r = await fetch('/api/config', {
      method: 'PUT',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(payload),
    });
    if (!r.ok) throw new Error(await r.text());
    const el = document.getElementById('settings-saved');
    el.style.display = 'block';
    setTimeout(() => el.style.display = 'none', 4000);
  } catch (e) {
    const el = document.getElementById('settings-error');
    el.textContent = 'Error: ' + e.message;
    el.style.display = 'block';
    setTimeout(() => el.style.display = 'none', 6000);
  }
}
</script>
