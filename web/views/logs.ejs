<div class="page">
  <div class="page-header">
    <h1>Logs</h1>
    <div>
      <button class="btn btn-secondary" onclick="refreshLogs()">Refresh</button>
      <button class="btn btn-danger" onclick="clearLogs()">Clear All</button>
    </div>
  </div>

  <div class="log-summary" id="log-summary"></div>

  <table class="data-table clickable" id="logs-table">
    <thead>
      <tr>
        <th>Time</th>
        <th>Sender</th>
        <th>Recipient</th>
        <th>Subject</th>
        <th>Status</th>
        <th>Error</th>
      </tr>
    </thead>
    <tbody></tbody>
  </table>

  <div class="pagination" id="log-pagination"></div>
</div>

<div id="log-detail-modal" class="modal" style="display:none">
  <div class="modal-content modal-wide">
    <h2>Email Detail</h2>
    <div id="log-detail-content"></div>
    <div class="form-actions">
      <button class="btn btn-secondary" onclick="closeModal('log-detail-modal')">Close</button>
    </div>
  </div>
</div>

<script>
const PAGE_SIZE = 50;
let currentPage = 0;

async function loadLogs(page = 0) {
  currentPage = page;
  const offset = page * PAGE_SIZE;
  const data = await fetch(`/api/logs?limit=${PAGE_SIZE}&offset=${offset}`).then(r => r.json());
  const tbody = document.querySelector('#logs-table tbody');
  tbody.innerHTML = data.logs.map(l => `
    <tr onclick="showLogDetail(${l.id})" title="Click for details">
      <td>${l.timestamp}</td>
      <td>${h(l.sender)}</td>
      <td>${h(l.recipient)}</td>
      <td>${h(l.subject)}</td>
      <td><span class="badge badge-${l.status}">${l.status}</span></td>
      <td class="error-cell">${h(l.error || '')}</td>
    </tr>
  `).join('') || '<tr><td colspan="6" class="empty">No logs yet</td></tr>';

  document.getElementById('log-summary').textContent = `Showing ${offset+1}-${Math.min(offset+PAGE_SIZE, data.total)} of ${data.total} entries`;

  const totalPages = Math.ceil(data.total / PAGE_SIZE);
  const pagination = document.getElementById('log-pagination');
  pagination.innerHTML = '';
  for (let i = 0; i < totalPages && i < 20; i++) {
    const btn = document.createElement('button');
    btn.className = `btn btn-sm ${i === page ? 'btn-primary' : 'btn-secondary'}`;
    btn.textContent = i + 1;
    btn.onclick = () => loadLogs(i);
    pagination.appendChild(btn);
  }
}

async function showLogDetail(id) {
  const d = document.getElementById('log-detail-content');
  d.innerHTML = '<p style="color:var(--text-muted)">Loading...</p>';
  document.getElementById('log-detail-modal').style.display = 'flex';
  try {
    const log = await fetch(`/api/logs/${id}`).then(r => r.json());
    let html = '<table class="info-table">';
    html += `<tr><td>Time</td><td>${h(log.timestamp)}</td></tr>`;
    html += `<tr><td>From</td><td>${h(log.sender)}</td></tr>`;
    html += `<tr><td>To</td><td>${h(log.recipient)}</td></tr>`;
    html += `<tr><td>Subject</td><td>${h(log.subject)}</td></tr>`;
    html += `<tr><td>Status</td><td><span class="badge badge-${log.status}">${log.status}</span></td></tr>`;
    if (log.error) html += `<tr><td>Error</td><td style="color:var(--danger)">${h(log.error)}</td></tr>`;
    html += '</table>';

    if (log.attachments && log.attachments.length) {
      html += '<h3>Attachments</h3><ul>';
      for (const a of log.attachments) {
        html += `<li>${h(a.name)} (${h(a.type)}, ${a.size} bytes)</li>`;
      }
      html += '</ul>';
    }

    if (log.body) {
      html += `<h3>Body</h3>`;
      html += `<pre style="white-space:pre-wrap;font-family:inherit;background:var(--bg);padding:1rem;border-radius:6px;border:1px solid var(--border);max-height:400px;overflow-y:auto;font-size:0.875rem;line-height:1.5;">${h(log.body)}</pre>`;
    }

    d.innerHTML = html;
  } catch (e) {
    d.innerHTML = `<p style="color:var(--danger)">Failed to load: ${h(e.message)}</p>`;
  }
}

function refreshLogs() { loadLogs(currentPage); }

async function clearLogs() {
  if (!confirm('Delete all logs?')) return;
  await fetch('/api/logs', { method: 'DELETE' });
  loadLogs(0);
}

loadLogs(0);
</script>
